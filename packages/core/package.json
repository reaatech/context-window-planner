{
  "name": "@reaatech/context-window-planner",
  "version": "0.1.0",
  "description": "Optimize token allocation within LLM context windows",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "license": "MIT",
  "author": "Rick Somers <rick@reaatech.com> (https://reaatech.com)",
  "homepage": "https://github.com/reaatech/context-window-planner/tree/main/packages/core#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/reaatech/context-window-planner.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/reaatech/context-window-planner/issues"
  },
  "keywords": [
    "llm",
    "context-window",
    "token-budget",
    "packing",
    "rag",
    "conversation",
    "typescript"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "js-tiktoken": "^1.0.10"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@vitest/coverage-v8": "3.2.4",
    "tsup": "^8.0.1",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false
}
